NODE_ENV=development
PORT=3000

# Postgres connection string (Neon in production; unused when running on PGlite)
DATABASE_URL=postgres://user:password@localhost:5432/rekord

# Auth
JWT_SECRET=change-me

# Comma-separated list of allowed CORS origins
APP_ORIGINS=http://localhost:3000

# Comma-separated integration providers to enable (fake is the safe default — no real OAuth creds needed)
PROVIDERS=fake
